#####################
# License
#
# YOU MUST OBTAIN A VALID LICENSE BEFORE STARTING THE CONTAINER THE
# FIRST TIME!
#
#####################
LICENSE_KEY=
LICENSE_REMOTE=true

#####################
# Database encryption
#####################
# Secret used for database encryption. WARNING: DO NOT MODIFY THIS
# after using any encrypted fields.
DB_SECRET=123secret123

#####################
# API Server
#####################
API_SERVER_VERSION=9.7.4
API_DEBUG=""

# Administrator account.
ADMIN_EMAIL=admin@example.com
ADMIN_PASS=CHANGEME
ADMIN_KEY=thisIsMyXAdminKey

# JWT signing secret.
JWT_SECRET=123secret123

# Enable the Developer Portal.
PORTAL_ENABLED=1

PORTAL_SECRET=changeme

# 60s for keep alive timeout. This must be greater than the timeout
# for the load balancer, if any.
KEEP_ALIVE_TIMEOUT=60000

FORMIO_VM_TIMEOUT=1000

#####################
# PDF Server
#####################

PDF_SERVER_VERSION=5.13.1
PDF_DEBUG=""

# S3 Storage
FORMIO_S3_BUCKET=files
FORMIO_S3_REGION=us-east-1
FORMIO_S3_PREFIX=localhost/

# S3 Authentication
FORMIO_S3_KEY=admin@example.com
FORMIO_S3_SECRET=CHANGEME

# ????????
# FORMIO_PDF_ADMINKEY=

#####################
# Mongo
#####################
MONGO_VERSION=8.2
MONGO_DATABASE=demo
MONGO_USER=admin
MONGO_PASSWORD=admin
MONGO_TLS=false

#####################
# External Ports

EXTERNAL_FORMIO_PORT=3000

# The S3-compatible service MUST be exposed to the client browser for
# file uploads via the File Upload Component.
EXTERNAL_S3_PORT=9000
EXTERNAL_S3_CONSOLE_PORT=9001
